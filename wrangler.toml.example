name = "bolshe-ticker-hub"
main = "src/index.js"
compatibility_date = "2026-04-08"

[assets]
directory = "./public"
binding = "ASSETS"
run_worker_first = true

[vars]
PUBLIC_BASE_URL = "https://ticker-domain.example"
NEWS_REFRESH_SECONDS = "120"
DEFAULT_FOOTBALL_TICKER_SPEED = "70"
DEFAULT_TENNIS_TICKER_SPEED = "100"

# Create KV namespace and fill ids.
# [[kv_namespaces]]
# binding = "TICKER_KV"
# id = ""
# preview_id = ""
