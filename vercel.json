{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": "python -m pip install -r requirements.txt",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 300,
      "excludeFiles": "{node_modules/**,.wrangler/**,public/**,releases/**,reference/**,src/**,test/**,tests/**,*.md,package-lock.json,wrangler.toml,wrangler.toml.example}"
    }
  }
}
